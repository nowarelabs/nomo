.{{tableName}}-table-container {
  padding: 20px;
}
.{{tableName}}-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.{{tableName}}-table {
  width: 100%;
  border-collapse: collapse;
}
.{{tableName}}-table th, .{{tableName}}-table td {
  padding: 12px;
  border-bottom: 1px solid #eee;
  text-align: left;
}
.{{tableName}}-form {
  margin-top: 20px;
  background: #f9f9f9;
  padding: 16px;
  border-radius: 4px;
}
.{{tableName}}-form input {
  margin-bottom: 8px;
  padding: 8px;
  border: 1px solid #ddd;
}
.btn {
  padding: 8px 16px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
}
.btn-primary { background: #3b82f6; color: white; }
.btn-success { background: #22c55e; color: white; }
.btn-secondary { background: #6b7280; color: white; }
.btn-danger { background: #ef4444; color: white; }
.btn-sm { padding: 4px 8px; font-size: 12px; }
.actions { display: flex; gap: 8px; }
