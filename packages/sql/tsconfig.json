{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["es2024"],
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "types": ["node"],
    "declaration": true,
    "outDir": "dist"
  },
  "include": ["src/**/*"]
}
