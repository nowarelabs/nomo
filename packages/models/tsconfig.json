{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "types": ["@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "@noblackbox/router": ["../router/src"],
      "@noblackbox/logger": ["../logger/src"],
      "@noblackbox/sql": ["../sql/src"],
      "@noblackbox/result": ["../result/src"]
    }
  },
  "include": ["src/**/*"]
}
