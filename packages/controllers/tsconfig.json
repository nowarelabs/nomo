{
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": ["@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "@noblackbox/router": ["../router/src"],
      "@noblackbox/models": ["../models/src"],
      "@noblackbox/logger": ["../logger/src"],
      "@noblackbox/views": ["../views/src"],
      "@noblackbox/assets": ["../assets/src"]
    }
  },
  "include": ["src/**/*"]
}
