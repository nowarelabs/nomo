{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*"]
}
