{
  "name": "nomo",
  "version": "0.0.0",
  "private": true,
  "description": "nomo framework - production-grade TypeScript framework for Cloudflare Workers",
  "type": "module",
  "scripts": {
    "publish": "node scripts/publish.js",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --build"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^0.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.2",
    "vite-plus": "latest",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
